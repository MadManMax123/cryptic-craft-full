# --- node page env vars ---

# iframe src for the embed block
EMBED_URL=https://tourmaline-froyo-d90865.netlify.app/

# secret key for HMAC-SHA256 answer verification
HMAC_SECRET=a3ce4edc7987f929aac9bfa273cf1bb5c7ef049e413eeb9ca2718c054878420b

# the correct answer, lowercase, plaintext. Compared via HMAC-SHA256
# at request time (not a plain string match) so verify.js never does a
# direct comparison of raw strings.
ANSWER=park street

#https://tinyurl.com/4rryd5vm

# flag returned to the client once the answer is verified
FLAG=FLAG{NULL_ENIGMA_BREAK}

# NOTE: clue.txt is not an env var — deploy the actual clue.txt file in the
# same /api directory as verify.js. Its contents are hashed (SHA-256) server
# side and only the digest is sent to the browser, where it's printed to
# the console after a correct submission.
