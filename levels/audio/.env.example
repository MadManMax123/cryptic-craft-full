# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env.local for local development
# Set all of these in the Vercel dashboard under Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# SHA-256 hash of the normalized correct answer
# (lowercase, stripped to [a-z0-9 ], spaces collapsed and trimmed)
ANSWER_HASH=e77fda0aae406429846bc6de1ee78a28e4b40f7eaa54d636a2b57b8620c55323

# The CTF flag returned to the player after solving
FLAG=FLAG{SPECTRO_FREQ_ANALYSIS}

# A random high-entropy string used to HMAC-sign the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=ec9766e306ea154c7dbfb4d741ad43b74a3172d2766cf5bc6a4c842817e48b2d

# Informational only — not used server-side (next clue is logged to the browser console)
NEXT_CLUE=node-interf.vercel.app
