# ─────────────────────────────────────────────────────────────────────────────
# NULL Challenge — Environment Variables
#
# Copy this file to .env.local for local development with `vercel dev`.
# Set all of these in the Vercel dashboard under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Session (login cookie) ────────────────────────────────────────────────────
# Any long random string — used to HMAC-sign the null_session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=599940c8f962db537689b6f5881e16c543374579006be28527378737c9a1f92f5c169f7ef1078196e69310aa926b049c

# ── Level 1 ───────────────────────────────────────────────────────────────────
# SHA-256 hex of the correct answer (lowercase).
# Generate with: echo -n "thomas shelby" | sha256sum
LEVEL1_ANSWER_HASH=5c8d3094e4e0e8e2f55f5a4ccfc39f3d26d8bd639b66a3c590a7dce8a2f84863

# Separate secret for the level1_access cookie (never share with SESSION_SECRET).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
LEVEL1_COOKIE_SECRET=e42716104a08cd96177edad333f888556f78fef1c7e0b59da076adf331129337aa5be6cb0b8fac57e0951eeb645e2457

# The flag string revealed to teams upon completing Level 1.
LEVEL1_FLAG=FLAG{CHANNEL_SIGNAL_CONFIRMED}

LEVEL1_HINTS=["The signal begins with sound.","Decoding once is not enough.","The output lies and is corrupted.","","","","+3/-3"]


